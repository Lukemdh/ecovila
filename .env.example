# Supabase (required)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Alias accepted by code: SERVICE_ROLE_KEY

# Cron and site URLs
ECOVILA_CRON_SECRET=
# Optional site URL override. Alias accepted by code: SITE_URL
ECOVILA_SITE_URL=
# Optional comma-separated CORS allowlist override. Defaults to the known EcoVila origins.
ECOVILA_ALLOWED_ORIGINS=

# SMS.md (required token/from; optional endpoint override)
SMSMD_API_TOKEN=
SMSMD_FROM=
SMSMD_API_URL=

# Resend (required API key/from; optional endpoint override)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_API_URL=

# Maib (required payment credentials/signature/base URL; optional callback override)
MAIB_CLIENT_ID=
MAIB_CLIENT_SECRET=
MAIB_SIGNATURE_KEY=
MAIB_BASE_URL=
MAIB_CALLBACK_URL=
